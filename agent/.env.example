# API Keys
PERPLEXITY_API_KEY=your_perplexity_key_here
OPENAI_API_KEY=your_openai_key_here
SENDGRID_API_KEY=your_sendgrid_key_here

# Email Config
FROM_EMAIL=treasury-agent@yourdomain.com
FROM_NAME=PI Treasury Intelligence Agent
TO_EMAILS=treasury@piindustries.com,cfo@piindustries.com

# Scheduling (IST = UTC+5:30)
BRIEFING_HOUR_IST=7
BRIEFING_MINUTE_IST=30
DATA_FETCH_HOUR_IST=6
DATA_FETCH_MINUTE_IST=0

# Alert Thresholds
USDINR_UPPER=86.00
USDINR_LOWER=83.00
FORWARD_PREMIUM_ALERT_BPS=10
CRUDE_UPPER=90.0

# App
LOG_LEVEL=INFO
DB_PATH=data/treasury.db
